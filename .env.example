# Base de données PostgreSQL (Supabase, Neon, Railway...)
# Laisse vide pour lancer en mode DEMO (données fictives, sans DB).
DATABASE_URL=

# Cloudinary (stockage images) — requis pour l'upload réel
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# URL publique du site (pour les liens WhatsApp partagés)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Phase de lancement : false = seul l'admin publie ; true = publication ouverte au public
NEXT_PUBLIC_PUBLISHING_OPEN=false
# Numéro WhatsApp de l'équipe Zako
NEXT_PUBLIC_ZAKO_WHATSAPP=

# Accès au panel admin (/admin) — OBLIGATOIRE en production
ADMIN_USER=admin
ADMIN_PASSWORD=

# Secret de signature des sessions + hachage OTP — OBLIGATOIRE
AUTH_SECRET=

# SMS Twilio pour l'OTP — vide = mode stub (code dans les logs)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
